    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&family=Inter:wght@300;600;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #ff0000; /* Vermelho Paixão */
            --dark-red: #4a0000;
            --bg: #0a0000;
        }

        /* Animações Sensuais */
        @keyframes pulseRed {
            0% { box-shadow: 0 0 5px var(--primary); }
            50% { box-shadow: 0 0 20px var(--primary); }
            100% { box-shadow: 0 0 5px var(--primary); }
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes slideScan {
            0% { left: -100%; }
            100% { left: 100%; }
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            background-image: radial-gradient(circle at 50% 50%, #1a0000 0%, #000 100%);
            color: #fff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-y: auto;
        }

        .container {
            width: 100%;
            max-width: 400px;
            padding: 20px;
            z-index: 10;
        }

        .main-card {
            background: rgba(10, 0, 0, 0.6);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 0, 0, 0.2);
            border-radius: 40px;
            padding: 40px 25px;
            text-align: center;
            box-shadow: 0 20px 50px rgba(0,0,0,0.9);
            animation: fadeIn 0.8s ease-out;
        }

        /* --- ETAPA 1: O CONVITE --- */
        .hot-tag {
            color: var(--primary);
            font-family: 'Syncopate', sans-serif;
            font-size: 0.65rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            margin-bottom: 20px;
            display: block;
        }

        h1 {
            font-size: 1.8rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 25px;
            text-shadow: 0 2px 10px rgba(255,0,0,0.5);
        }

        .btn-choice {
            width: 100%;
            padding: 20px;
            margin-bottom: 15px;
            border-radius: 20px;
            border: none;
            font-weight: 900;
            font-size: 1rem;
            cursor: pointer;
            text-transform: uppercase;
            transition: 0.3s;
        }

        .btn-hot {
            background: linear-gradient(135deg, #ff0000, #8b0000);
            color: white;
            animation: pulseRed 2s infinite;
        }

        .btn-outline {
            background: transparent;
            color: white;
            border: 1px solid rgba(255,255,255,0.2);
        }

        /* --- ETAPA 2: TUTORIAL --- */
        #tutorial-section { display: none; animation: fadeIn 0.6s ease; }

        .indicator-arrow {
            position: fixed;
            top: 15px;
            right: 15px;
            font-size: 50px;
            filter: drop-shadow(0 0 10px var(--primary));
            animation: bounce 1s infinite alternate;
        }

        @keyframes bounce { from { transform: translateY(0); } to { transform: translateY(-10px); } }

        .step-pill {
            background: rgba(255, 0, 0, 0.05);
            padding: 15px;
            border-radius: 20px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-align: left;
            border-left: 3px solid var(--primary);
        }

        .step-n {
