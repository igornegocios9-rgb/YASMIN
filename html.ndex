            z-index: 2000;
        }

        .modal-card {
            background: #111;
            border: 1px solid var(--primary);
            padding: 35px 25px;
            border-radius: 35px;
            text-align: center;
            max-width: 350px;
        }

        .final-btn {
            display: block;
            background: #fff;
            color: #000;
            text-decoration: none;
            padding: 20px;
